@page "/"
@attribute [Authorize]

<PageTitle>Home</PageTitle>

<div class="welcome-banner">
    <h1>Welcome back!</h1>
    <p class="lead">Message friends your guardian has approved.</p>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card friend-card">
            <div class="card-body">
                <h2 class="h5">Your friend code</h2>
                <p class="friend-code mb-0">@_friendCode</p>
                <p class="text-muted small mb-0">Share this with a friend so they can connect.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card friend-card">
            <div class="card-body">
                <h2 class="h5">Ready to chat?</h2>
                <p class="mb-3">Pick a friend and start a conversation.</p>
                <a class="btn btn-primary" href="friends">Go to friends</a>
            </div>
        </div>
    </div>
</div>

@code {
    private string _friendCode = "FROG42";
}

@page "/login"
@layout EmptyLayout
@using Tadpole.Client.Shared.Models

<PageTitle>Sign in</PageTitle>

<div class="login-shell">
    <div class="card login-card shadow-sm">
        <div class="card-body p-4">
            <h1 class="h3 mb-1">Guardian sign in</h1>
            <p class="text-muted mb-4">Authentication endpoints are not wired yet. Use dev sign-in to explore the portal.</p>

            <EditForm Model="_form" OnValidSubmit="SignIn">
                <div class="mb-3">
                    <label class="form-label" for="email">Email</label>
                    <InputText id="email" class="form-control" @bind-Value="_form.Email" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="password">Password</label>
                    <InputText id="password" type="password" class="form-control" @bind-Value="_form.Password" />
                </div>
                <button class="btn btn-primary w-100" type="submit">Dev sign in</button>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Inject] private AuthSession Session { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private LoginForm _form = new() { Email = "guardian@example.com" };

    private async Task SignIn()
    {
        var displayName = string.IsNullOrWhiteSpace(_form.Email) ? "Guardian" : _form.Email.Split('@')[0];
        await Session.SignInAsync(new AuthSessionInfo(
            AccessToken: "dev-guardian-token",
            Role: TadpoleRole.Guardian,
            UserId: Guid.NewGuid(),
            DisplayName: displayName));

        Navigation.NavigateTo("/");
    }

    private sealed class LoginForm
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}

@page "/connections"
@attribute [Authorize]
@using Tadpole.Domain.Entities

<PageTitle>Connections</PageTitle>

<h1>Friend connections</h1>
<p class="text-muted">Approve or revoke 1:1 connections between children you supervise.</p>

<div class="card">
    <div class="card-body">
        @if (_connections.Count == 0)
        {
            <p class="text-muted mb-0">No connection requests.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Friend</th>
                            <th>Status</th>
                            <th>Requested</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var connection in _connections)
                        {
                            <tr>
                                <td>@connection.FriendDisplayName</td>
                                <td><span class="badge @GetBadgeClass(connection.State)">@connection.State</span></td>
                                <td>@connection.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td class="text-end">
                                    @if (connection.State is ConnectionState.Requested or ConnectionState.GuardianLoApproved)
                                    {
                                        <button class="btn btn-sm btn-primary me-1" @onclick="() => Approve(connection)">Approve</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => Revoke(connection)">Deny</button>
                                    }
                                    else if (connection.State == ConnectionState.Active)
                                    {
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => Revoke(connection)">Revoke</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(_status))
{
    <p class="text-success mt-3">@_status</p>
}

@code {
    private readonly List<ConnectionSummary> _connections =
    [
        new(Guid.NewGuid(), Guid.NewGuid(), Guid.NewGuid(), "Sam (friend of Alex)", ConnectionState.Requested, DateTimeOffset.UtcNow.AddDays(-1)),
        new(Guid.NewGuid(), Guid.NewGuid(), Guid.NewGuid(), "Riley (friend of Jordan)", ConnectionState.Active, DateTimeOffset.UtcNow.AddDays(-14))
    ];

    private string? _status;

    private void Approve(ConnectionSummary connection)
    {
        _status = $"Approved connection with {connection.FriendDisplayName} (UI preview).";
    }

    private void Revoke(ConnectionSummary connection)
    {
        _status = $"Revoked connection with {connection.FriendDisplayName} (UI preview).";
    }

    private static string GetBadgeClass(ConnectionState state) => state switch
    {
        ConnectionState.Active => "text-bg-success",
        ConnectionState.Revoked => "text-bg-secondary",
        _ => "text-bg-warning"
    };
}
